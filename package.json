{
  "name": "indie-md",
  "type": "module",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev": "astro dev",
    "extract-advice": "npx tsx scripts/extract-advice.ts",
    "build": "npm run extract-advice && astro build",
    "preview": "astro preview",
    "format": "biome format --write .",
    "lint": "biome lint --write .",
    "lint:writing": "bash scripts/lint-writing.sh",
    "lint:seo": "bash scripts/lint-seo.sh",
    "typecheck": "astro sync && tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "check": "biome check . && npm run lint:writing && npm run typecheck && npm run test && npm run build && npm run lint:seo",
    "prepare": "husky"
  },
  "dependencies": {
    "@astrojs/sitemap": "^3.7.1",
    "@astrojs/tailwind": "^6.0.2",
    "@tailwindcss/typography": "^0.5.19",
    "astro": "^6.0.7",
    "remark-directive": "^4.0.0",
    "tailwindcss": "^3.4.19"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.8",
    "@types/node": "^25.5.0",
    "husky": "^9.1.7",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  }
}
