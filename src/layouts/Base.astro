---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';
import { assetPath } from "../lib/base-url";
import { canonicalUrl } from "../lib/canonical";

interface Props {
  title: string;
  description?: string;
  canonicalPath?: string;
  ogType?: string;
  ogImage?: string;
  ogImageAlt?: string;
  twitterCreator?: string;
  /**
   * When true, advertise a Markdown mirror of this page for LLM ingestion
   * via `<link rel="alternate" type="text/markdown">`. Derived from
   * `canonicalPath` by appending `.md` and stripping the trailing slash.
   */
  markdownMirror?: boolean;
}

const {
  title,
  description,
  canonicalPath,
  ogType,
  ogImage,
  ogImageAlt,
  twitterCreator,
  markdownMirror,
} = Astro.props;
const site = "https://indie.md";
const resolvedOgImage = `${site}${ogImage ?? "/og-image.png"}`;
const resolvedCanonical = canonicalPath ? canonicalUrl(canonicalPath) : undefined;
const resolvedImageAlt =
  ogImageAlt ?? "indie.md: Real Stories. Real Advice. A knowledge platform for indie hackers.";
const markdownMirrorUrl =
  markdownMirror && canonicalPath
    ? `${site}${canonicalPath.replace(/\/+$/, "")}.md`
    : undefined;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#e66b1a" />
    <!-- Unlock full text + images in Google AI Overviews, Bing Copilot, and
         Discover. Defaults cap snippets at ~160 chars which is too short for
         LLM citation to pick an answer paragraph out of the page. -->
    <meta name="robots" content="index, follow, max-snippet:-1, max-image-preview:large, max-video-preview:-1" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    {description && <meta name="description" content={description} />}
    {resolvedCanonical && <link rel="canonical" href={resolvedCanonical} />}

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    {description && <meta property="og:description" content={description} />}
    <meta property="og:type" content={ogType ?? "website"} />
    {resolvedCanonical && <meta property="og:url" content={resolvedCanonical} />}
    <meta property="og:site_name" content="indie.md" />
    <meta property="og:locale" content="en_US" />
    <meta property="og:image" content={resolvedOgImage} />
    <meta property="og:image:alt" content={resolvedImageAlt} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content="@vtemian" />
    {twitterCreator && <meta name="twitter:creator" content={twitterCreator} />}
    <meta name="twitter:image" content={resolvedOgImage} />
    <meta name="twitter:image:alt" content={resolvedImageAlt} />
    <meta name="twitter:title" content={title} />
    {description && <meta name="twitter:description" content={description} />}

    <link rel="alternate" type="application/rss+xml" title="indie.md" href="/rss.xml" />
    {markdownMirrorUrl && (
      <link rel="alternate" type="text/markdown" title={`${title} (Markdown)`} href={markdownMirrorUrl} />
    )}
    <title>{title}</title>
  </head>
  <body>
    <div class="min-h-screen flex flex-col">
      <Header />
      <main class="flex-1">
        <slot />
      </main>
      <Footer />
    </div>
  </body>
</html>
