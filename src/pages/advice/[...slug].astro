---
import Base from '../../layouts/Base.astro';
import AdviceCard from '../../components/AdviceCard.astro';
import CategoryBadge from '../../components/CategoryBadge.astro';
import { getCollection, getEntry, type CollectionEntry } from 'astro:content';
import { getAdviceIndex, getAdviceByCategory, getAllCategories } from '../../lib/advice';
import type { AdviceEntry, CategoryMeta } from '../../lib/advice';
import { assetPath, href } from "../../lib/base-url";

type CategoryProps = { type: 'category'; category: CategoryMeta };
type AdviceProps = { type: 'advice'; advice: AdviceEntry };
type Props = CategoryProps | AdviceProps;

export async function getStaticPaths() {
  const { getAdviceIndex, getAllCategories } = await import('../../lib/advice');
  const adviceIndex = getAdviceIndex();
  const categories = getAllCategories();

  const categoryPaths = categories.map((cat) => ({
    params: { slug: cat.slug },
    props: { type: 'category' as const, category: cat },
  }));

  const advicePaths = adviceIndex.map((a) => ({
    params: { slug: a.slug },
    props: { type: 'advice' as const, advice: a },
  }));

  return [...categoryPaths, ...advicePaths];
}

const props = Astro.props;
const { slug } = Astro.params;
const categories = getAllCategories();

type AdviceWithPerson = { advice: AdviceEntry; person: CollectionEntry<'people'>; categoryLabel: string };

let filteredAdvice: AdviceWithPerson[] = [];
let advicePerson: CollectionEntry<'people'> | undefined;
let adviceCategory: CategoryMeta | undefined;

if (props.type === 'category') {
  const journeys = await getCollection('journeys');
  const events = await getCollection('events');
  const journeyDateMap = new Map(journeys.map(j => [j.id, j.data.date]));
  const eventDateMap = new Map(events.map(e => [e.id, e.data.date]));

  const entries = getAdviceByCategory(props.category.slug);
  const sorted = [...entries].sort((a, b) => {
    const dateA = (a.eventSlug ? eventDateMap.get(a.eventSlug) : null)
      ?? (a.journeySlug ? journeyDateMap.get(a.journeySlug) : null)
      ?? new Date(0);
    const dateB = (b.eventSlug ? eventDateMap.get(b.eventSlug) : null)
      ?? (b.journeySlug ? journeyDateMap.get(b.journeySlug) : null)
      ?? new Date(0);
    return dateB.getTime() - dateA.getTime();
  });

  filteredAdvice = await Promise.all(
    sorted.map(async (a) => {
      const person = await getEntry('people', a.personSlug);
      const cat = categories.find(c => c.slug === a.category);
      return { advice: a, person: person!, categoryLabel: cat?.label ?? a.category };
    })
  );
}

let sourceTitle = "";

if (props.type === 'advice') {
  advicePerson = await getEntry('people', props.advice.personSlug);
  adviceCategory = categories.find(c => c.slug === props.advice.category);
  if (props.advice.eventSlug) {
    const sourceEvent = await getEntry('events', props.advice.eventSlug);
    sourceTitle = sourceEvent?.data.title ?? "";
  } else if (props.advice.journeySlug) {
    const sourceJourney = await getEntry('journeys', props.advice.journeySlug);
    sourceTitle = sourceJourney?.data.title ?? "";
  }
}

const isCategory = props.type === 'category';
const category = isCategory ? props.category : undefined;
const advice = isCategory ? undefined : props.advice;

const pageTitle = isCategory
  ? `${category!.label} Advice | indie.md`
  : `${advice!.title} | indie.md`;

const pageDescription = isCategory
  ? `${category!.label} tips from indie hackers who've been there.`
  : advice!.content.slice(0, 160);
---
<Base title={pageTitle} description={pageDescription} canonicalPath={`/advice/${slug}`}>
  {isCategory && category && (
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "CollectionPage",
      "name": `${category.label} Advice`,
      "description": `${category.label} tips from indie hackers who've been there.`,
      "url": `https://indie.md/advice/${category.slug}`,
      "publisher": { "@type": "Organization", "name": "indie.md", "url": "https://indie.md" },
      "numberOfItems": category.count,
    })} />
  )}
  {!isCategory && advice && advicePerson && (
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Article",
      "headline": advice.title,
      "description": advice.content.slice(0, 160),
      "url": `https://indie.md/advice/${advice.slug}`,
      "author": { "@type": "Person", "name": advicePerson.data.name },
      "publisher": { "@type": "Organization", "name": "indie.md", "url": "https://indie.md" },
    })} />
  )}
  {isCategory && category && (
    <section class="container mx-auto px-4 pt-16 pb-8 md:pt-20">
      <div class="max-w-2xl">
        <h1 class="font-display text-4xl md:text-5xl leading-[1.1] tracking-tight text-foreground mb-4 flex items-center gap-3">
          <img src={category.icon} alt={category.label} class="w-12 h-12 rounded-lg" /> {category.label}
        </h1>
        <p class="text-lg text-muted-foreground leading-relaxed">
          {category.count} tips from real indie hacker journeys.
        </p>
      </div>
    </section>
  )}

  {isCategory && category && (
    <section class="container mx-auto px-4 pb-8">
      <div class="flex flex-wrap items-center gap-2">
        <a href={href("/advice")}
           class="inline-flex items-center gap-1 px-4 py-2 rounded-full text-sm font-medium border border-border/80 text-muted-foreground hover:border-primary/30 hover:text-foreground transition-all">
          All
        </a>
        {categories.map((cat) => (
          <a href={href(`/advice/${cat.slug}`)}
             class:list={[
               'inline-flex items-center gap-1 px-4 py-2 rounded-full text-sm font-medium',
               cat.slug === category!.slug
                 ? 'bg-primary text-primary-foreground'
                 : 'border border-border/80 text-muted-foreground hover:border-primary/30 hover:text-foreground transition-all',
             ]}>
            <img src={cat.icon} alt={cat.label} class="w-4 h-4" /> {cat.label}
          </a>
        ))}
      </div>
    </section>
  )}

  {isCategory && category && (
    <section class="container mx-auto px-4 pb-20">
      <div class="divide-y divide-border/60">
        {filteredAdvice.map(({ advice, person, categoryLabel }) => (
          <AdviceCard
            advice={advice}
            person={person.data}
            categoryLabel={categoryLabel}
          />
        ))}
      </div>
    </section>
  )}

  {!isCategory && advice && (
    <article class="container mx-auto px-4 pt-16 pb-20 md:pt-20">
      <!-- Back link -->
      <a href={href("/advice")} class="inline-flex items-center gap-1 text-sm text-muted-foreground hover:text-foreground transition-colors mb-8">
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m12 19-7-7 7-7"/><path d="M19 12H5"/></svg>
        All advice
      </a>

      <!-- Category badge -->
      {adviceCategory && (
        <div class="mb-4">
          <a href={href(`/advice/${adviceCategory.slug}`)}>
            <CategoryBadge category={adviceCategory.slug} label={adviceCategory.label} icon={adviceCategory.icon} />
          </a>
        </div>
      )}

      <!-- Title -->
      <h1 class="font-display text-3xl md:text-5xl leading-[1.1] tracking-tight text-foreground mb-6">
        {advice.title}
      </h1>

      <!-- Author -->
      {advicePerson && (
        <div class="flex items-center gap-3 mb-8">
          <img src={assetPath(advicePerson.data.avatar)} alt={advicePerson.data.name} class="w-8 h-8 rounded-full object-cover" />
          <div>
            <a href={href(`/people/${advice.personSlug}`)} class="text-sm font-semibold text-foreground hover:text-primary transition-colors">
              {advicePerson.data.name}
            </a>
            <p class="text-xs text-muted-foreground italic">{advicePerson.data.tagline}</p>
          </div>
        </div>
      )}

      <!-- Content -->
      <div class="prose prose-lg max-w-2xl prose-p:text-muted-foreground prose-p:leading-relaxed">
        <p>{advice.content}</p>
      </div>

      <!-- Source -->
      <div class="mt-12 max-w-2xl">
        <p class="text-sm text-muted-foreground mb-3">Extracted from</p>
        {advice.eventSlug ? (
          <a href={href(`/events/${advice.eventSlug}`)}
             class="group flex items-center gap-3 rounded-xl border border-border/80 bg-card p-5 hover:border-primary/30 hover:shadow-[var(--shadow-card)] transition-all">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-muted-foreground group-hover:text-primary transition-colors" aria-hidden="true"><rect width="18" height="18" x="3" y="4" rx="2" ry="2"/><line x1="16" x2="16" y1="2" y2="6"/><line x1="8" x2="8" y1="2" y2="6"/><line x1="3" x2="21" y1="10" y2="10"/></svg>
            <span class="font-display text-lg text-foreground group-hover:text-primary transition-colors">
              {sourceTitle || "View the full event"}
            </span>
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-muted-foreground group-hover:text-primary transition-colors ml-auto" aria-hidden="true"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
          </a>
        ) : (
          <a href={href(`/journeys/${advice.journeySlug}`)}
             class="group flex items-center gap-3 rounded-xl border border-border/80 bg-card p-5 hover:border-primary/30 hover:shadow-[var(--shadow-card)] transition-all">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-muted-foreground group-hover:text-primary transition-colors" aria-hidden="true"><path d="M12 7v14"/><path d="M3 18a1 1 0 0 1-1-1V4a1 1 0 0 1 1-1h5a4 4 0 0 1 4 4 4 4 0 0 1 4-4h5a1 1 0 0 1 1 1v13a1 1 0 0 1-1 1h-6a3 3 0 0 0-3 3 3 3 0 0 0-3-3z"/></svg>
            <span class="font-display text-lg text-foreground group-hover:text-primary transition-colors">
              {sourceTitle || "View the full journey"}
            </span>
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-muted-foreground group-hover:text-primary transition-colors ml-auto" aria-hidden="true"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
          </a>
        )}
      </div>
    </article>
  )}
</Base>
