---
import Base from '../../layouts/Base.astro';
import AdviceCard from '../../components/AdviceCard.astro';
import { getCollection, getEntry } from 'astro:content';
import { getAdviceIndex, getAllCategories } from '../../lib/advice';
import { href } from '../../lib/base-url';

const adviceIndex = getAdviceIndex();
const categories = getAllCategories();

const journeys = await getCollection('journeys');
const events = await getCollection('events');
const journeyDateMap = new Map(journeys.map(j => [j.id, j.data.date]));
const eventDateMap = new Map(events.map(e => [e.id, e.data.date]));

const sortedAdvice = [...adviceIndex].sort((a, b) => {
  const dateA = (a.eventSlug ? eventDateMap.get(a.eventSlug) : null)
    ?? (a.journeySlug ? journeyDateMap.get(a.journeySlug) : null)
    ?? new Date(0);
  const dateB = (b.eventSlug ? eventDateMap.get(b.eventSlug) : null)
    ?? (b.journeySlug ? journeyDateMap.get(b.journeySlug) : null)
    ?? new Date(0);
  return dateB.getTime() - dateA.getTime();
});

const adviceWithPeople = await Promise.all(
  sortedAdvice.map(async (a) => {
    const person = await getEntry('people', a.personSlug);
    const cat = categories.find(c => c.slug === a.category);
    return { advice: a, person: person!, categoryLabel: cat?.label ?? a.category };
  })
);
---
<Base title="Advice | indie.md" description="Practical tips extracted from real indie hacker journeys. Browse by category or explore them all." canonicalPath="/advice">
  <section class="container mx-auto px-4 pt-16 pb-8 md:pt-20">
    <div class="max-w-2xl">
      <h1 class="font-display text-4xl md:text-5xl leading-[1.1] tracking-tight text-foreground mb-4">
        Advice
      </h1>
      <p class="text-lg text-muted-foreground leading-relaxed">
        Practical tips extracted from real indie hacker journeys. Every piece of advice comes from someone who's actually done it.
      </p>
    </div>
  </section>

  <!-- Category filters -->
  <section class="container mx-auto px-4 pb-8">
    <div class="flex flex-wrap items-center gap-2">
      <a href={href("/advice")}
         class="inline-flex items-center gap-1 px-4 py-2 rounded-full text-sm font-medium bg-primary text-primary-foreground">
        All
      </a>
      {categories.map((cat) => (
        <a href={href(`/advice/${cat.slug}`)}
           class="inline-flex items-center gap-1 px-4 py-2 rounded-full text-sm font-medium border border-border/80 text-muted-foreground hover:border-primary/30 hover:text-foreground transition-all">
          <img src={cat.icon} alt={cat.label} class="w-4 h-4" /> {cat.label}
        </a>
      ))}
    </div>
  </section>

  <!-- Advice list -->
  <section class="container mx-auto px-4 pb-20">
    <div class="divide-y divide-border/60">
      {adviceWithPeople.map(({ advice, person, categoryLabel }) => (
        <AdviceCard
          advice={advice}
          person={person.data}
          categoryLabel={categoryLabel}
        />
      ))}
    </div>
  </section>
</Base>
