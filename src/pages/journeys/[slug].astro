---
import Base from '../../layouts/Base.astro';
import CategoryBadge from '../../components/CategoryBadge.astro';
import { getCollection, getEntry, render } from 'astro:content';
import { getAdviceForJourney, getAllCategories } from '../../lib/advice';
import { assetPath, href } from "../../lib/base-url";

export async function getStaticPaths() {
  const journeys = await getCollection('journeys');
  return journeys.map((j) => ({
    params: { slug: j.id },
    props: { journey: j },
  }));
}

const { journey } = Astro.props;
const person = await getEntry('people', journey.data.person);
const adviceList = getAdviceForJourney(journey.id);
const categories = getAllCategories();
const categoryMap = new Map(categories.map(c => [c.slug, c]));

const { Content } = await render(journey);

const formattedDate = journey.data.date.toLocaleDateString('en-US', {
  month: 'long',
  day: 'numeric',
  year: 'numeric',
});
---
<Base title={`${journey.data.title} | indie.md`} description={journey.data.subtitle} canonicalPath={`/journeys/${journey.id}`} ogType="article">
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": journey.data.title,
    "description": journey.data.subtitle,
    "datePublished": journey.data.date.toISOString(),
    "author": {
      "@type": "Person",
      "name": person!.data.name
    },
    "publisher": {
      "@type": "Organization",
      "name": "indie.md",
      "url": "https://indie.md"
    }
  })} />
  <article class="container mx-auto px-4 pt-16 pb-20 md:pt-20">
    <!-- Back link -->
    <a href={href("/journeys")} class="inline-flex items-center gap-1 text-sm text-muted-foreground hover:text-foreground transition-colors mb-8">
      <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m12 19-7-7 7-7"/><path d="M19 12H5"/></svg>
      All journeys
    </a>

    <!-- Author card -->
    <div class="flex items-center gap-4 mb-8">
      <img src={assetPath(person!.data.avatar)} alt={person!.data.name} class="w-16 h-16 rounded-full object-cover" />
      <div>
        <a href={href(`/people/${journey.data.person}`)} class="font-semibold text-foreground hover:text-primary transition-colors">
          {person!.data.name}
        </a>
        <p class="text-sm text-muted-foreground italic">{person!.data.tagline}</p>
        <p class="text-xs text-muted-foreground mt-1">{formattedDate}</p>
      </div>
    </div>

    <!-- Title -->
    <h1 class="font-display text-3xl md:text-5xl leading-[1.1] tracking-tight text-foreground mb-3">
      {journey.data.title}
    </h1>
    <p class="text-lg text-muted-foreground leading-relaxed mb-10 max-w-2xl">
      {journey.data.subtitle}
    </p>

    <!-- Key Lessons -->
    <div class="rounded-xl border border-primary/20 bg-primary/5 p-6 mb-12 max-w-2xl">
      <h2 class="font-display text-lg text-foreground flex items-center gap-2 mb-4">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M15 14c.2-1 .7-1.7 1.5-2.5 1-.9 1.5-2.2 1.5-3.5A6 6 0 0 0 6 8c0 1 .2 2.2 1.5 3.5.7.7 1.3 1.5 1.5 2.5"/><path d="M9 18h6"/><path d="M10 22h4"/></svg>
        Key Lessons
      </h2>
      <ul class="space-y-2">
        {journey.data.lessons.map((lesson: string) => (
          <li class="flex items-start gap-2 text-sm text-foreground">
            <span class="text-primary mt-0.5">&#x2022;</span>
            {lesson}
          </li>
        ))}
      </ul>
    </div>

    <!-- Journey content -->
    <div class="prose prose-lg max-w-2xl
      prose-headings:font-display prose-headings:text-foreground prose-headings:tracking-tight
      prose-p:text-muted-foreground prose-p:leading-relaxed
      prose-strong:text-foreground
      prose-a:text-primary prose-a:no-underline hover:prose-a:underline
      prose-li:text-muted-foreground
      prose-blockquote:border-primary/40 prose-blockquote:text-muted-foreground">
      <Content />
    </div>

    <!-- Advice extracted from this journey -->
    {adviceList.length > 0 && (
      <div class="mt-16 max-w-2xl">
        <h2 class="font-display text-2xl text-foreground mb-6 flex items-center gap-2">
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M9.937 15.5A2 2 0 0 0 8.5 14.063l-6.135-1.582a.5.5 0 0 1 0-.962L8.5 9.936A2 2 0 0 0 9.937 8.5l1.582-6.135a.5.5 0 0 1 .963 0L14.063 8.5A2 2 0 0 0 15.5 9.937l6.135 1.581a.5.5 0 0 1 0 .964L15.5 14.063a2 2 0 0 0-1.437 1.437l-1.582 6.135a.5.5 0 0 1-.963 0z"/><path d="M20 3v4"/><path d="M22 5h-4"/></svg>
          Advice extracted from this journey
        </h2>
        <div class="space-y-3">
          {adviceList.map((a) => {
            const cat = categoryMap.get(a.category);
            return (
              <a href={href(`/advice/${a.slug}`)}
                 class="group flex items-start gap-4 rounded-xl border border-border/80 bg-card p-5 hover:border-primary/30 hover:shadow-[var(--shadow-card)] transition-all">
                <div class="flex-1">
                  <div class="flex items-center gap-2 mb-1">
                    {cat && (
                      <CategoryBadge category={cat.slug} label={cat.label} icon={cat.icon} />
                    )}
                  </div>
                  <h3 class="font-display text-lg text-foreground group-hover:text-primary transition-colors">
                    {a.title}
                  </h3>
                  <p class="text-sm text-muted-foreground mt-1 line-clamp-2">{a.content}</p>
                </div>
                <span class="text-muted-foreground group-hover:text-primary transition-colors mt-1">
                  <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
                </span>
              </a>
            );
          })}
        </div>
      </div>
    )}
  </article>
</Base>
