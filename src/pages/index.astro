---
import Base from '../layouts/Base.astro';
import JourneyCard from '../components/JourneyCard.astro';
import EventCard from '../components/EventCard.astro';
import AdviceCard from '../components/AdviceCard.astro';
import { getCollection, getEntry } from 'astro:content';
import { getAdviceIndex, getAdviceForEvent, getAllCategories } from '../lib/advice';

const journeys = await getCollection('journeys');
const adviceIndex = getAdviceIndex();
const categories = getAllCategories();

const journeysWithPeople = await Promise.all(
  journeys.map(async (j) => {
    const person = await getEntry('people', j.data.person);
    const adviceCount = adviceIndex.filter(a => a.journeySlug === j.id).length;
    return { journey: j, person: person!, adviceCount };
  })
);

const events = await getCollection('events');
const eventsWithData = await Promise.all(
  events.map(async (e) => {
    const presenters = await Promise.all(
      e.data.presenters.map(async (slug: string) => {
        const person = await getEntry('people', slug);
        return person!.data;
      })
    );
    const adviceCount = getAdviceForEvent(e.id).length;
    return { event: e, presenters, adviceCount };
  })
);

const categoryMap = new Map(categories.map(c => [c.slug, c]));

const latestAdvice = await Promise.all(
  adviceIndex.slice(0, 5).map(async (a) => {
    const person = await getEntry('people', a.personSlug);
    return { advice: a, person: person!, categoryLabel: categoryMap.get(a.category)?.label ?? a.category };
  })
);
---
<Base title="indie.md | Learn from indie hackers who've been there">
  <!-- Hero -->
  <section class="container mx-auto px-4 pt-16 pb-14 md:pt-24 md:pb-20">
    <div class="max-w-2xl">
      <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-primary/10 text-primary text-xs font-medium mb-6">
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9.937 15.5A2 2 0 0 0 8.5 14.063l-6.135-1.582a.5.5 0 0 1 0-.962L8.5 9.936A2 2 0 0 0 9.937 8.5l1.582-6.135a.5.5 0 0 1 .963 0L14.063 8.5A2 2 0 0 0 15.5 9.937l6.135 1.581a.5.5 0 0 1 0 .964L15.5 14.063a2 2 0 0 0-1.437 1.437l-1.582 6.135a.5.5 0 0 1-.963 0z"/><path d="M20 3v4"/><path d="M22 5h-4"/></svg>
        Real stories from real builders
      </div>
      <h1 class="font-display text-4xl md:text-6xl leading-[1.1] tracking-tight text-foreground mb-5">
        Learn from indie hackers<br />
        <span class="text-primary italic">who've been there.</span>
      </h1>
      <p class="text-lg text-muted-foreground leading-relaxed max-w-lg">
        Case studies, hard-won lessons, and practical advice from our community. Every tip is extracted from a real journey, no generic fluff.
      </p>
    </div>
  </section>

  <!-- Journeys -->
  <section class="container mx-auto px-4 pb-16">
    <div class="flex items-center justify-between mb-8">
      <h2 class="font-display text-2xl text-foreground flex items-center gap-2">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 7v14"/><path d="M3 18a1 1 0 0 1-1-1V4a1 1 0 0 1 1-1h5a4 4 0 0 1 4 4 4 4 0 0 1 4-4h5a1 1 0 0 1 1 1v13a1 1 0 0 1-1 1h-6a3 3 0 0 0-3 3 3 3 0 0 0-3-3z"/></svg>
        Journeys
      </h2>
      <a href="/journeys" class="text-sm text-primary font-medium flex items-center gap-1 hover:gap-2 transition-all">
        View all
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
      </a>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-5">
      {journeysWithPeople.map(({ journey, person, adviceCount }) => (
        <JourneyCard
          journey={{ slug: journey.id, ...journey.data }}
          person={person.data}
          adviceCount={adviceCount}
        />
      ))}
    </div>
  </section>

  <!-- Events -->
  {eventsWithData.length > 0 && (
    <section class="container mx-auto px-4 pb-16">
      <div class="flex items-center justify-between mb-8">
        <h2 class="font-display text-2xl text-foreground flex items-center gap-2">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="18" x="3" y="4" rx="2" ry="2"/><line x1="16" x2="16" y1="2" y2="6"/><line x1="8" x2="8" y1="2" y2="6"/><line x1="3" x2="21" y1="10" y2="10"/></svg>
          Events
        </h2>
        <a href="/events" class="text-sm text-primary font-medium flex items-center gap-1 hover:gap-2 transition-all">
          View all
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </a>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
        {eventsWithData.map(({ event, presenters, adviceCount }) => (
          <EventCard
            event={{ slug: event.id, ...event.data }}
            presenters={presenters}
            adviceCount={adviceCount}
          />
        ))}
      </div>
    </section>
  )}

  <!-- Advice by Category -->
  <section class="container mx-auto px-4 pb-16">
    <div class="flex items-center justify-between mb-8">
      <h2 class="font-display text-2xl text-foreground">Advice by Category</h2>
      <a href="/advice" class="text-sm text-primary font-medium flex items-center gap-1 hover:gap-2 transition-all">
        Browse all
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
      </a>
    </div>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-5 gap-3">
      {categories.map((cat) => (
        <a href={`/advice/${cat.slug}`}
           class="group flex items-center gap-3 rounded-xl border border-border/80 bg-card px-5 py-4 hover:border-primary/30 hover:shadow-[var(--shadow-card)] transition-all">
          <span class="text-2xl">{cat.icon}</span>
          <div>
            <p class="text-sm font-semibold text-foreground group-hover:text-primary transition-colors">{cat.label}</p>
            <p class="text-xs text-muted-foreground">{cat.count} tips</p>
          </div>
        </a>
      ))}
    </div>
  </section>

  <!-- Latest Advice -->
  <section class="container mx-auto px-4 pb-16">
    <div class="flex items-center justify-between mb-8">
      <h2 class="font-display text-2xl text-foreground">Latest Advice</h2>
    </div>
    <div class="divide-y divide-border/60">
      {latestAdvice.map(({ advice, person, categoryLabel }) => (
        <AdviceCard
          advice={advice}
          person={person.data}
          categoryLabel={categoryLabel}
        />
      ))}
    </div>
  </section>

  <!-- CTA -->
  <section class="container mx-auto px-4 pb-20">
    <div class="rounded-2xl bg-primary/5 border border-primary/20 p-10 md:p-14 text-center">
      <h2 class="font-display text-3xl md:text-4xl text-foreground mb-4">
        Have a story to share?
      </h2>
      <p class="text-muted-foreground max-w-md mx-auto mb-6">
        indie.md is built by the community. If you've learned something the hard way, your experience could save someone else months of struggle.
      </p>
      <a href="mailto:hello@indie.md"
         class="inline-flex items-center gap-2 px-6 py-3 rounded-full bg-primary text-primary-foreground font-medium hover:opacity-90 transition-opacity">
        Share your journey
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
      </a>
    </div>
  </section>
</Base>
