---
interface Props {
  person: {
    slug: string;
    name: string;
    avatar: string;
    tagline: string;
    bio: string;
  };
  products?: { name: string; url: string }[];
}

import { assetPath, href } from "../lib/base-url";

const { person, products } = Astro.props;
---

<a href={href(`/people/${person.slug}`)}
   class="group block rounded-xl border border-border/80 bg-card p-6 hover:shadow-[var(--shadow-card-hover)] hover:border-primary/30 transition-all duration-300">
  <div class="flex items-center gap-4 mb-3">
    <img src={assetPath(person.avatar)} alt={person.name} class="w-14 h-14 rounded-full object-cover" />
    <div>
      <p class="font-semibold text-foreground group-hover:text-primary transition-colors">{person.name}</p>
      <p class="text-sm text-muted-foreground italic">{person.tagline}</p>
    </div>
  </div>
  <p class="text-sm text-muted-foreground leading-relaxed">{person.bio}</p>
  {products && products.length > 0 && (
    <div class="flex flex-wrap gap-1.5 mt-3">
      {products.map((p) => (
        <span class="text-xs font-medium text-primary bg-primary/10 px-2 py-0.5 rounded">
          {p.name}
        </span>
      ))}
    </div>
  )}
</a>
