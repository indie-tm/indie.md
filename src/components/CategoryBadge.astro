---
interface Props {
  category: string;
  label: string;
  icon: string;
  active?: boolean;
}

const { category, label, icon, active = false } = Astro.props;
---

<span class:list={[
  'inline-flex items-center gap-1 px-3 py-1.5 rounded-full text-xs font-semibold uppercase tracking-wider',
  active ? 'bg-primary text-primary-foreground' : 'bg-primary/10 text-primary',
]}>
  <span aria-hidden="true">{icon}</span> {label}
</span>
